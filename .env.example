# Copy to .env.local for local E2E runs.

# App URL (optional — defaults to http://localhost:3000)
E2E_BASE_URL=http://localhost:3000

# Required: valid test account with permission to edit the target CV
E2E_USER_EMAIL=admin@example.com
E2E_USER_PASSWORD=your-password-here

# Optional: target a specific CV by name (defaults to the first CV in the list)
E2E_CV_NAME=

# Optional: pick a specific catalog skill when adding (defaults to the first option)
E2E_SKILL_NAME=

# GraphQL endpoint used by the app
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
